# Copy this file to .env and adjust values as needed.

# Application
# -----------

# Publicly accessible URL of the application
BASE_URL=http://localhost:5173

# File storage directory to store application data and network files
DATA_DIR=./data

# Database
# --------

# Database URL (SQLite and PostgreSQL is supported)
DATABASE_URL=sqlite:///./data/pypsa-app.db

# Authentication
# --------------

# Enable GitHub OAuth authentication
ENABLE_AUTH=false

# GitHub OAuth app client ID (create at https://github.com/settings/developers)
# GITHUB_CLIENT_ID=

# GitHub OAuth app client secret
# GITHUB_CLIENT_SECRET=

# Secret key for session cookies (generate with: openssl rand -base64 32)
# SESSION_SECRET_KEY=dev-secret-key-change-in-production

# Session time-to-live in seconds (default: 7 days)
# SESSION_TTL=604800

# GitHub username that becomes admin on first login
# ADMIN_GITHUB_USERNAME=

# Redis
# -----

# Redis connection URL for caching (optional)
# REDIS_URL=

# Time-to-live in seconds for plot cache entries
# PLOT_CACHE_TTL=86400

# Time-to-live in seconds for network cache entries
# NETWORK_CACHE_TTL=7200

# Maximum cache size in megabytes
# MAX_CACHE_SIZE_MB=50

# Executions
# ----------

# Comma-separated list of Snakedispatch backends in name=url format
# SNAKEDISPATCH_BACKENDS=cluster-a=http://snakedispatch-a:8000,cluster-b=http://snakedispatch-b:8000

# Time-to-live in seconds for run output file list cache entries
# RUN_OUTPUTS_CACHE_TTL=10800

# AI
# --

# API key for the LLM provider (required to enable chat).
# For Ollama the value is ignored but must be set — use the literal 'ollama'.
# ANTHROPIC_API_KEY=ollama

# Override to use an Anthropic-compatible provider:
#   Ollama:       http://localhost:11434
#   OpenRouter:   https://openrouter.ai/api/v1
#   llama.cpp:    http://localhost:8080
# ANTHROPIC_BASE_URL=http://localhost:11434

# Default model used when the chat request doesn't specify one.
#   Ollama example:     qwen3.5:9b  (pull first: `ollama pull qwen3.5:9b`)
#   Anthropic example:  claude-opus-4-7
# LLM_MODEL_DEFAULT=qwen3.5:9b

# Enable extended thinking (reasoning) in replies. Off by default — thinking
# tokens count against max_tokens and many local models waste output on it.
# LLM_THINKING_ENABLED=false

# Token budget passed to the provider when thinking is enabled. Ollama
# accepts but does not enforce it; Anthropic classic models require it
# strictly less than LLM_MAX_TOKENS.
# LLM_THINKING_BUDGET_TOKENS=4000

# Maximum tokens the model may generate per chat response.
# LLM_MAX_TOKENS=16000

# Maximum number of tool-use round-trips per chat request.
# LLM_MAX_TOOL_ITERATIONS=10

# System prompt prepended to every chat conversation.
# LLM_SYSTEM_PROMPT="You are a helpful assistant for PyPSA..."

# Development
# -----------

# Run backend only without serving the frontend
BACKEND_ONLY=false

# Comma-separated list of allowed CORS origins (only used in backend-only mode)
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Docker Compose
# --------------
# These variables are only used by Docker Compose, not by the Python application.

# Application port
APP_PORT=8000

# PostgreSQL settings (used by postgres container and to build DATABASE_URL)
POSTGRES_HOST=postgres
POSTGRES_DB=pypsa_app
POSTGRES_USER=pypsa_app
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432
