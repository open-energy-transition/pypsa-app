{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": false,
    "noEmit": true
  },
  "include": [".sandcastle/**/*"],
  "exclude": [".sandcastle/worktrees/**", ".sandcastle/logs/**"]
}
